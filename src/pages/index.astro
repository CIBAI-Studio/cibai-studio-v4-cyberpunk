  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!isOpen));
        const lines = menuBtn.querySelectorAll('.mobile-menu-line');
        if (!isOpen) {
          lines[0]?.classList.add('translate-y-[4px]', 'rotate-45');
          lines[1]?.classList.add('opacity-0');
          lines[2]?.classList.add('-translate-y-[4px]', '-rotate-45');
        } else {
          lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
          lines[1]?.classList.remove('opacity-0');
          lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
        }
      });

      mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          menuBtn.setAttribute('aria-expanded', 'false');
          const lines = menuBtn.querySelectorAll('.mobile-menu-line');
          lines[0]?.classList.remove('translate-y-[4px]', 'rotate-45');
          lines[1]?.classList.remove('opacity-0');
          lines[2]?.classList.remove('-translate-y-[4px]', '-rotate-45');
        });
      });
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(this: HTMLAnchorElement, e: Event) {
        e.preventDefault();
        const href = this.getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });

    // Intersection Observer for scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-fade-in-up');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.card-brutal').forEach(el => {
      (el as HTMLElement).style.opacity = '0';
      observer.observe(el);
    });

    // HUD Clock
    const clockEl = document.getElementById('hud-clock');
    if (clockEl) {
      const updateClock = () => {
        const now = new Date();
        clockEl.textContent = now.toLocaleTimeString('es-ES', { hour12: false });
      };
      updateClock();
      setInterval(updateClock, 1000);
    }

    // Typing effect for hero terminal
    const typingEl = document.getElementById('typing-text');
    if (typingEl) {
      const lines = [
        '> Desarrollamos sitios web y webapps que impactan.',
        '> Sin artificios. Sin genéricos. Sin compromiso.',
        '> Ready.'
      ];
      let lineIdx = 0;
      let charIdx = 0;
      let currentText = '';

      const typeChar = () => {
        if (lineIdx >= lines.length) return;
        if (charIdx < lines[lineIdx].length) {
          currentText += lines[lineIdx][charIdx];
          typingEl.textContent = currentText;
          charIdx++;
          setTimeout(typeChar, 30 + Math.random() * 40);
        } else {
          currentText += '\n';
          lineIdx++;
          charIdx = 0;
          if (lineIdx < lines.length) {
            setTimeout(typeChar, 400);
          }
        }
      };
      setTimeout(typeChar, 1200);
    }

    // Hero Slider
    const heroSlides = document.querySelectorAll('.hero-slide');
    const heroDots = document.querySelectorAll('.hero-dot');
    const heroProgress = document.getElementById('hero-progress');
    const heroCounter = document.getElementById('hero-slide-counter');
    const SLIDE_DURATION = 6000;
    let currentSlide = 0;
    let slideTimer: ReturnType<typeof setTimeout> | null = null;

    function setSlide(idx: number) {
      heroSlides.forEach((s, i) => {
        s.classList.toggle('active', i === idx);
      });
      heroDots.forEach((d, i) => {
        d.classList.toggle('active', i === idx);
      });
      if (heroCounter) {
        heroCounter.textContent = `0${idx + 1} / 0${heroSlides.length}`;
      }
      currentSlide = idx;
      startProgress();
    }

    function startProgress() {
      if (!heroProgress) return;
      heroProgress.classList.remove('running');
      heroProgress.style.transitionDuration = '0ms';
      heroProgress.style.width = '0%';
      void heroProgress.offsetWidth;
      heroProgress.style.transitionDuration = `${SLIDE_DURATION}ms`;
      heroProgress.classList.add('running');
      heroProgress.style.width = '100%';

      if (slideTimer) clearTimeout(slideTimer);
      slideTimer = setTimeout(() => {
        setSlide((currentSlide + 1) % heroSlides.length);
      }, SLIDE_DURATION);
    }

    heroDots.forEach(dot => {
      dot.addEventListener('click', () => {
        const idx = parseInt((dot as HTMLElement).dataset.slide || '0', 10);
        setSlide(idx);
      });
    });

    if (heroSlides.length > 1) {
      startProgress();
    }

    // Contact form terminal echo
    const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
    const terminalOutput = document.getElementById('terminal-output');
    if (contactForm && terminalOutput) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = (document.getElementById('contact-name') as HTMLInputElement)?.value || '';
        const email = (document.getElementById('contact-email') as HTMLInputElement)?.value || '';
        const project = (document.getElementById('contact-project') as HTMLSelectElement)?.value || '';
        const message = (document.getElementById('contact-message') as HTMLTextAreaElement)?.value || '';

        const esc = (s: string) => { const d = document.createElement('span'); d.textContent = s; return d.innerHTML; };
        const echo = document.createElement('div');
        echo.innerHTML = `
          <div class="mt-4 text-cyber-teal">$ send_project --from="${esc(name)}"</div>
          <div class="mt-1 text-cyber-text/80">
            <div><span class="text-cyber-orange">FROM:</span> ${esc(name)} &lt;${esc(email)}&gt;</div>
            <div><span class="text-cyber-orange">TYPE:</span> ${esc(project)}</div>
            <div><span class="text-cyber-orange">MSG:</span> ${esc(message.slice(0, 80))}${message.length > 80 ? '...' : ''}</div>
            <div class="mt-1 text-cyber-teal">&#10003; Mensaje recibido. Responderemos en &lt;48h.</div>
          </div>
        `;
        // Remove last line (cursor)
        const lastLine = terminalOutput.querySelector(':scope > div:last-child');
        if (lastLine) lastLine.remove();
        terminalOutput.appendChild(echo);

        const cursor = document.createElement('div');
        cursor.className = 'mt-4 text-cyber-teal';
        cursor.innerHTML = '$ <span class="typing-cursor text-cyber-orange">█</span>';
        terminalOutput.appendChild(cursor);

        contactForm.reset();

        // Also open mailto as fallback
        window.location.href = `mailto:hola@cibai.studio?subject=Proyecto: ${project}&body=Nombre: ${name}%0AEmail: ${email}%0A%0A${encodeURIComponent(message)}`;
      });
    }
  </script>
