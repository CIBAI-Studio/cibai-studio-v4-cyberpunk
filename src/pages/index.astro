---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const services = [
  {
    num: '01',
    label: 'DISEÑO_WEB',
    title: 'Diseño Web Premium',
    description: 'Interfaces visuales que convierten. Diseño UI/UX con identidad de marca, tipografía de alto contraste y animaciones con propósito. Nada genérico, todo a medida.',
    tags: ['UI/UX', 'FIGMA', 'BRANDING'],
  },
  {
    num: '02',
    label: 'WEBAPPS_MEDIDA',
    title: 'Webapps a Medida',
    description: 'Aplicaciones web completas desde cero. React, Next.js, APIs, autenticación y dashboards. Soluciones por escalón con tu negocio y se adaptan a tus procesos.',
    tags: ['NEXT.JS', 'REACT', 'TS', 'TRPC'],
  },
  {
    num: '03',
    label: 'COMERCIO_ELECTRÓNICO',
    title: 'Comercio Electrónico',
    description: 'Tiendas online de alto rendimiento. Integración con pasarelas de pago, gestión de inventario, panel de administración y optimización para conversión máxima.',
    tags: ['SHOPIFY', 'STRIPE', 'NEXT.JS'],
  },
  {
    num: '04',
    label: 'SOLUCIONES_MEDIDA',
    title: 'Soluciones a Medida',
    description: 'Desde integraciones de terceros hasta sistemas complejos. Si tienes un problema técnico específico, lo resolvemos con el stack más adecuado para tu caso.',
    tags: ['NODE.JS', 'POSTGRES', 'REST', 'DEPLOY'],
  },
];

const processSteps = [
  {
    num: '01',
    title: 'BRIEFING',
    description: 'Entendemos tu visión, tus objetivos y los retos que quieres resolver. Sin briefing sólido no hay proyecto sólido.',
  },
  {
    num: '02',
    title: 'DISEÑO',
    description: 'Cada pixel, cada interacción pensada desde la estrategia. Prototipamos antes de escribir una línea de código.',
  },
  {
    num: '03',
    title: 'DESARROLLO',
    description: 'Código limpio, modular y documentado. Sprints ágiles con entregas regulares. Ves el progreso desde el día uno.',
  },
  {
    num: '04',
    title: 'REVISIÓN',
    description: 'Iteramos contigo hasta que el resultado no solo cumpla tus expectativas, sino que las supere con creces.',
  },
  {
    num: '05',
    title: 'LANZAMIENTO',
    description: 'Deploy controlado, verificaciones técnicas y puesta en marcha. El lanzamiento es el principio, no el final.',
  },
];

const portfolioItems = [
  {
    title: 'VOLKANIK STUDIO',
    category: 'Diseño Web + Branding',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600&h=400&fit=crop',
  },
  {
    title: 'ANTREX SAAS',
    category: 'Webapp + Automatización',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=400&fit=crop',
  },
  {
    title: 'RAYA EDITORIAL',
    category: 'E-commerce + SEO',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=400&fit=crop',
  },
  {
    title: 'NEROMA LABS',
    category: 'Desarrollo Full-Stack',
    image: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&h=400&fit=crop',
  },
];

const values = [
  {
    num: '01',
    title: 'BRUTALIDAD',
    description: 'El diseño que no hace declaraciones no dice nada. Cada decisión visual es una posición.',
  },
  {
    num: '02',
    title: 'PRECISIÓN',
    description: 'Un píxel fuera de lugar es un error. No entregamos hasta que el código y el diseño coincidan exactamente.',
  },
  {
    num: '03',
    title: 'VELOCIDAD',
    description: 'Los plazos no son sugerencias. Trabajamos rápido sin comprometer ni un milímetro de calidad.',
  },
];

const tickerItems = ['ASTRO', 'NEXT.JS', 'REACT', 'TAILWIND', 'TYPESCRIPT', 'NODE.JS', 'POSTGRES', 'SUPABASE', 'VERCEL', 'FIGMA', 'AI/ML', 'PYTHON', 'GRAPHQL', 'DOCKER'];
---

<Layout
  title="CIBAI Studio — Hacemos la web brutal"
  description="Agencia de diseño web, desarrollo de aplicaciones e inteligencia artificial para empresas en España. Diseño cyberpunk, código brutal, resultados reales."
>
  <!-- ═══════════════ TOP BAR (HUD) ═══════════════ -->
  <div class="fixed top-0 left-0 right-0 z-50 bg-cyber-black border-b border-cyber-border/50">
    <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-8">
      <div class="flex items-center gap-4">
        <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-teal"></span>
        <span class="font-mono text-[9px] text-cyber-text/60 uppercase tracking-widest">SYS.ONLINE</span>
        <span class="font-mono text-[9px] text-cyber-border">|</span>
        <span class="font-mono text-[9px] text-cyber-teal/70">NODE_ACTIVE</span>
        <span class="hud-blink-slow inline-block w-1 h-1 rounded-full bg-cyber-orange ml-1"></span>
      </div>
      <div class="hidden sm:flex items-center gap-4">
        <span class="font-mono text-[9px] text-cyber-text/40">PING: <span class="text-cyber-teal/70">8ms</span></span>
        <span class="font-mono text-[9px] text-cyber-border">|</span>
        <span class="font-mono text-[9px] text-cyber-text/40">UPTIME: <span class="text-cyber-orange/70">99.9%</span></span>
        <span class="font-mono text-[9px] text-cyber-border">|</span>
        <span class="hud-blink inline-block w-1.5 h-1.5 rounded-full bg-cyber-red"></span>
        <span class="font-mono text-[9px] text-cyber-text/40">REC</span>
        <span class="font-mono text-[9px] text-cyber-border">|</span>
        <span class="font-mono text-[9px] text-cyber-text/40" id="hud-clock">00:00:00</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════ NAV ═══════════════ -->
  <nav class="fixed top-8 left-0 right-0 z-50 border-b border-cyber-border bg-cyber-black/90 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-1">
        <span class="text-lg font-bold tracking-tight text-cyber-white">CIBAI</span>
        <span class="text-lg font-bold tracking-tight text-cyber-orange">.</span>
        <span class="text-lg font-light tracking-tight text-cyber-orange">STUDIO</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#main-content" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">Inicio</a>
        <a href="#servicios" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">Servicios</a>
        <a href="#proceso" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">Proceso</a>
        <a href="#portfolio" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">Portfolio</a>
        <a href="#studio" class="font-mono text-xs uppercase tracking-widest text-cyber-text hover:text-cyber-white transition-colors">Studio</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="#contacto" class="btn-primary text-xs py-2 px-5 hidden sm:inline-flex">PROYECTO</a>
        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 border border-cyber-border hover:border-cyber-orange transition-colors"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
          <span class="mobile-menu-line block w-5 h-px bg-cyber-white transition-all duration-300 mt-1.5"></span>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-cyber-border bg-cyber-black/95 backdrop-blur-md">
      <div class="px-6 py-6 space-y-4">
        <a href="#main-content" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">Inicio</a>
        <a href="#servicios" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">Servicios</a>
        <a href="#proceso" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">Proceso</a>
        <a href="#portfolio" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">Portfolio</a>
        <a href="#studio" class="mobile-nav-link block font-mono text-sm uppercase tracking-widest text-cyber-text hover:text-cyber-orange transition-colors py-2">Studio</a>
        <div class="pt-4 border-t border-cyber-border">
          <a href="#contacto" class="btn-primary text-xs w-full justify-center">SOLICITAR PROYECTO</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section id="main-content" class="relative min-h-[90vh] flex flex-col justify-start pt-32 pb-8 overflow-hidden hero-section">
    <div class="absolute inset-0 opacity-[0.03] hero-bg-grid" style="background-image: linear-gradient(rgba(255,77,0,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,77,0,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="mx-auto max-w-7xl px-6 w-full">
      <div class="max-w-4xl relative" style="min-height: 420px;" id="hero-slider">
        <!-- Slide 1 -->
        <div class="hero-slide active" id="hero-slide-0">
          <div class="font-mono text-xs text-cyber-text mb-6 animate-fade-in-up">
            <span class="text-cyber-orange">CIBAI_STUDIO</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span>BERGA, BARCELONA, ESPAÑA</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span class="text-cyber-teal">STATUS: ONLINE</span>
          </div>

          <h1 class="text-[clamp(3rem,8vw,7rem)] font-black leading-[0.9] tracking-tighter mb-8 animate-fade-in-up animate-delay-100 glitch-text" data-text="HACEMOS LA WEB BRUTAL">
            HACEMOS<br/>
            LA WEB<br/>
            <span class="text-cyber-orange glow-orange">BRUTAL</span>
          </h1>

          <div class="mb-10 animate-fade-in-up animate-delay-200">
            <div class="font-mono text-sm text-cyber-text max-w-xl leading-relaxed bg-cyber-dark/80 border border-cyber-border p-4">
              <span class="text-cyber-orange">$</span><span class="text-cyber-teal ml-1">cibai</span><span class="text-cyber-text ml-1">--init</span>
              <div class="mt-2" id="typing-container">
                <span id="typing-text" class="text-cyber-text/90"></span><span class="typing-cursor text-cyber-orange">█</span>
              </div>
            </div>
          </div>

          <div class="flex flex-wrap gap-4 mb-6 animate-fade-in-up animate-delay-300">
            <a href="#contacto" class="btn-primary btn-glitch">
              Solicitar Proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#portfolio" class="btn-secondary btn-glitch">Ver Proyectos</a>
          </div>
        </div>

        <!-- Slide 2 -->
        <div class="hero-slide" id="hero-slide-1">
          <div class="font-mono text-xs text-cyber-text mb-6">
            <span class="text-cyber-teal">PROTOCOL_V2</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span>CÓDIGO + DISEÑO + IA</span>
            <span class="mx-2 text-cyber-border">//</span>
            <span class="text-cyber-orange">SIGNAL: ACTIVE</span>
          </div>

          <h2 class="text-[clamp(3rem,8vw,7rem)] font-black leading-[0.9] tracking-tighter mb-8 glitch-text" data-text="TU IDEA NUESTRO CÓDIGO">
            TU IDEA<br/>
            NUESTRO<br/>
            <span class="text-cyber-teal glow-teal">CÓDIGO</span>
          </h2>

          <div class="mb-10">
            <div class="font-mono text-sm text-cyber-text max-w-xl leading-relaxed bg-cyber-dark/80 border border-cyber-border p-4">
              <span class="text-cyber-orange">$</span><span class="text-cyber-teal ml-1">deploy</span><span class="text-cyber-text ml-1">--mode=brutal</span>
              <div class="mt-2 text-cyber-text/90">
                > Webs, webapps y automatizaciones con IA.<br/>
                > Del concepto al deploy en semanas, no meses.<br/>
                > <span class="text-cyber-teal">Deploy completado.</span>
              </div>
            </div>
          </div>

          <div class="flex flex-wrap gap-4 mb-6">
            <a href="#servicios" class="btn-primary btn-glitch">
              Ver Servicios
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#contacto" class="btn-secondary btn-glitch">Contactar</a>
          </div>
        </div>

      </div>

      <!-- Slider dots -->
      <div class="flex items-center gap-4 mt-6 animate-fade-in-up animate-delay-500">
        <div class="hero-slider-dots" id="hero-dots">
          <button class="hero-dot active" data-slide="0" aria-label="Slide 1"></button>
          <button class="hero-dot" data-slide="1" aria-label="Slide 2"></button>
        </div>
        <div class="hero-slide-progress">
          <div class="hero-slide-progress-bar" id="hero-progress"></div>
        </div>
        <span class="font-mono text-[9px] text-cyber-text/50" id="hero-slide-counter">01 / 02</span>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <div class="w-px h-12 bg-gradient-to-b from-transparent to-cyber-orange/50"></div>
      <span class="font-mono text-[9px] text-cyber-text uppercase tracking-widest">Scroll</span>
    </div>
  </section>

  <!-- ═══════════════ TICKER ═══════════════ -->
  <div class="border-y border-cyber-border py-4 overflow-hidden bg-cyber-dark/50">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map((item) => (
        <span class="inline-flex items-center gap-4 px-6 font-mono text-sm text-cyber-text whitespace-nowrap">
          <span class="ticker-sep flex-shrink-0 flex items-center gap-[2px] text-cyber-orange font-bold text-xs" aria-hidden="true">
            <span class="inline-block -skew-x-12">///</span>
          </span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ═══════════════ SERVICIOS ═══════════════ -->
  <section id="servicios" class="py-32 relative">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-20">
        <div class="section-number mb-4">// SERVICIOS</div>
        <h2 class="text-[clamp(2.5rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight">
          NUESTROS<br/>
          <span class="text-cyber-teal glow-teal">SISTEMAS</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <div class="card-brutal p-8 flex flex-col h-full">
            <div class="flex items-baseline justify-between mb-6">
              <span class="font-mono text-[10px] text-cyber-teal uppercase tracking-widest">{service.label}</span>
              <span class="text-5xl font-black text-cyber-white/[0.07]">{service.num}</span>
            </div>
            <h3 class="text-xl font-bold mb-4 text-cyber-white">{service.title}</h3>
            <p class="text-sm text-cyber-text leading-relaxed mb-6 flex-1">{service.description}</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {service.tags.map((tag: string) => (
                <span class="font-mono text-[10px] px-2 py-1 border border-cyber-border text-cyber-text">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROCESO ═══════════════ -->
  <section id="proceso" class="py-32 border-t border-cyber-border relative">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-20">
        <div class="section-number mb-4">// PROCESO</div>
        <h2 class="text-[clamp(2.5rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight mb-4">
          PROCESO
        </h2>
        <p class="text-cyber-text max-w-lg font-light">
          Cada proyecto pasa por 5 fases. Nada se deja al azar. Todo se ejecuta con precisión militar.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {processSteps.map((step) => (
          <div class="card-brutal p-6 group">
            <span class="text-4xl font-black text-cyber-orange/80 block mb-4">{step.num}</span>
            <h3 class="font-mono text-sm font-bold tracking-wider mb-3 text-cyber-white">{step.title}</h3>
            <p class="text-xs text-cyber-text leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="#contacto" class="btn-secondary text-xs">
          Iniciar tu proyecto
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PORTFOLIO ═══════════════ -->
  <section id="portfolio" class="py-32 border-t border-cyber-border relative">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-20">
        <div class="section-number mb-4">// PORTFOLIO</div>
        <h2 class="text-[clamp(2.5rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight mb-4">
          PORTFOLIO
        </h2>
        <p class="text-cyber-text max-w-lg font-light">
          Proyectos que hablan por nosotros. Cada uno es una historia de transformación.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {portfolioItems.map((item) => (
          <div class="group relative aspect-[4/3] overflow-hidden border border-cyber-border cursor-pointer">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-30"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-cyber-black via-cyber-black/50 to-transparent"></div>

            <div class="absolute bottom-0 left-0 right-0 p-8 transition-all duration-500">
              <span class="font-mono text-[10px] text-cyber-orange uppercase tracking-widest block mb-2">{item.category}</span>
              <h3 class="text-2xl font-black tracking-tight text-cyber-white">{item.title}</h3>
            </div>

            <div class="absolute inset-4 border border-cyber-orange/0 group-hover:border-cyber-orange/30 transition-all duration-500 pointer-events-none"></div>

            <div class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center border border-cyber-border opacity-0 group-hover:opacity-100 transition-all duration-500 group-hover:border-cyber-orange">
              <svg class="w-4 h-4 text-cyber-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ STUDIO ═══════════════ -->
  <section id="studio" class="py-32 border-t border-cyber-border relative">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16">
        <div class="section-number mb-4">// STUDIO</div>
        <div class="section-divider mb-8"></div>
        <h2 class="text-[clamp(2.5rem,5vw,4.5rem)] font-black leading-[0.95] tracking-tight mb-4">
          STUDIO
        </h2>
        <p class="text-cyber-text text-lg font-light uppercase tracking-wider">
          Un equipo de dos que construye como diez.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-20">
        <div>
          <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-6">// FILOSOFÍA</div>
          <blockquote class="text-2xl md:text-3xl font-bold leading-snug mb-8 text-cyber-white">
            &ldquo;Creemos que el código bien escrito y el diseño brutal no son opuestos. Son lo mismo.&rdquo;
          </blockquote>
          <p class="text-sm text-cyber-text leading-relaxed mb-4">
            CIBAI nació de la convicción de que la mayoría de las webs son mediocres por elección, no por necesidad. Hacemos lo contrario: tomamos cada decisión con intención y entregamos solo lo que nos enorgullece.
          </p>

          <div class="grid grid-cols-3 gap-4 mt-10 pt-8 border-t border-cyber-border">
            <div>
              <span class="text-3xl font-black">47</span><span class="text-cyber-orange text-xl font-bold">Proyectos</span>
              <div class="font-mono text-[9px] text-cyber-text uppercase tracking-widest mt-1">ENTREGADOS</div>
            </div>
            <div>
              <span class="text-3xl font-black">100</span><span class="text-cyber-orange text-xl font-bold">%</span>
              <div class="font-mono text-[9px] text-cyber-text uppercase tracking-widest mt-1">CÓDIGO FUNCIONAL</div>
            </div>
            <div>
              <span class="text-3xl font-black">&lt; 48</span><span class="text-cyber-orange text-xl font-bold">h</span>
              <div class="font-mono text-[9px] text-cyber-text uppercase tracking-widest mt-1">RESPUESTA INICIAL</div>
            </div>
          </div>
        </div>

        <div>
          <div class="font-mono text-[10px] text-cyber-text uppercase tracking-widest mb-6">// VALORES</div>
          <div class="space-y-8">
            {values.map((value) => (
              <div class="flex gap-6 items-start">
                <span class="text-5xl font-black text-cyber-orange/70 leading-none flex-shrink-0">{value.num}</span>
                <div>
